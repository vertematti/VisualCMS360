import fs from 'node:fs/promises';
import path from 'node:path';
import * as cheerio from 'cheerio';
import Layout from '../layouts/Layout.astro';
import { loadSiteConfig, resolveSeo } from '../lib/seo';

export const prerender = false;

// Load pages fresh on every request (SSR) — no stale cache
const filePath = path.resolve(process.cwd(), 'src/data/pages.json');
let pages: Record<string, any> = {};
try {
  const fileData = await fs.readFile(filePath, 'utf-8');
  pages = JSON.parse(fileData);
} catch (e) {
  console.error("Could not load pages.json");
}

// Resolve slug from URL params
const rawSlug = Astro.params.slug;
const slug = rawSlug || 'index';
const pageData = pages[slug];

if (!pageData) {
  return new Response(null, { status: 404 });
}

// Load components data to inject the latest shared components
const componentsPath = path.resolve(process.cwd(), 'src/data/components.json');
let components: Record<string, any> = {};
try {
  const compData = await fs.readFile(componentsPath, 'utf-8');
  components = JSON.parse(compData);
} catch (e) {}

let finalHtml = pageData.html || '';
let finalCss = pageData.css || '';
let finalJs = '';       // JS puro agregado (componentes + página)
let finalJquery = '';   // Código jQuery agregado (vai dentro de $(function(){}))

if (finalHtml) {
  const $ = cheerio.load(finalHtml);
  
  $('[data-component-id]').each((i, el) => {
    const id = $(el).attr('data-component-id');
    if (id && components[id]) {
      $(el).html(components[id].html || '');
      finalCss += '\n' + (components[id].css || '');
      // Agregar JS puro do componente
      const compJs = components[id].js || '';
      if (compJs.trim()) finalJs += '\n/* == Componente: ' + id + ' (JS) == */\n' + compJs + '\n';
      // Agregar jQuery do componente (será envolvido em $(function(){}) depois)
      const compJq = components[id].jquery || '';
      if (compJq.trim()) finalJquery += '\n/* == Componente: ' + id + ' (jQuery) == */\n' + compJq + '\n';
    }
  });

  // Extract only the body content
  if (finalHtml.includes('<body')) {
    const bodyMatch = finalHtml.match(/<body[^>]*>([\s\S]*)<\/body>/i);
    finalHtml = bodyMatch ? bodyMatch[1] : $.html('body');
  } else {
    finalHtml = $.html();
  }
}

// Adicionar JS e jQuery próprios da página (se existirem)
if (pageData.js && pageData.js.trim()) {
  finalJs += '\n/* == Página: ' + slug + ' (JS) == */\n' + pageData.js + '\n';
}
if (pageData.jquery && pageData.jquery.trim()) {
  finalJquery += '\n/* == Página: ' + slug + ' (jQuery) == */\n' + pageData.jquery + '\n';
}

// Montar o bloco final de scripts:
// 1. JS puro roda imediatamente (após o HTML já estar no DOM)
// 2. jQuery roda dentro de $(function(){...}) garantindo DOM + jQuery prontos
let combinedScript = '';
if (finalJs.trim()) {
  combinedScript += finalJs + '\n';
}
if (finalJquery.trim()) {
  combinedScript += '\n// === jQuery agregado (DOM ready) ===\n';
  combinedScript += 'if (window.jQuery) {\n';
  combinedScript += '  jQuery(function ($) {\n';
  combinedScript += finalJquery.split('\n').map(l => '    ' + l).join('\n') + '\n';
  combinedScript += '  });\n';
  combinedScript += '} else {\n';
  combinedScript += '  console.warn("[VisualCMS360] jQuery não encontrado — código jQuery dos componentes não executado.");\n';
  combinedScript += '}\n';
}
// Resolver SEO: cascata página → site.json → fallback
const siteConfig = await loadSiteConfig();
const seo = resolveSeo(pageData.seo || {}, siteConfig, slug);
---

<Layout lang={seo.lang} seoTags={seo.tags}>
  <!-- CSS from GrapesJS — is:global para evitar scoping do Astro -->
  <!-- Necessário para position:sticky, position:fixed funcionarem -->
  <style is:global set:html={finalCss}></style>

  <!-- O wrapper [data-component-id] envolve cada componente compartilhado.
       Se ele gerar uma caixa própria, ela tem a altura do componente e
       PRENDE o position:sticky/fixed dos filhos (ex.: #navbar) a essa altura,
       fazendo o cabeçalho descolar do topo ao rolar a página.
       display:contents remove a caixa do wrapper (mantendo os atributos),
       tornando o filho um filho direto do body — o contexto de rolagem real. -->
  <style is:global>
    [data-component-id] { display: contents; }
  </style>

  <!-- Correção responsiva do grid do GrapesJS (.gjs-row / .gjs-cell):
       No layout padrão a linha é display:table e cada célula tem height:75px
       fixo. Em telas estreitas (<=768px) o GrapesJS troca a célula para
       display:block mas NÃO reseta a altura fixa nem o display:table da linha,
       fazendo o conteúdo transbordar de uma "tabela" de altura travada e o
       rodapé subir, sobrepondo a página. Aqui resetamos a altura da célula e
       tornamos a linha um bloco fluido, devolvendo o fluxo normal. -->
  <style is:global>
    @media (max-width: 768px) {
      .gjs-row { display: block; }
      .gjs-cell { height: auto; }
    }
  </style>
  
  <!-- Page HTML from GrapesJS -->
  <Fragment set:html={finalHtml} />

  <!-- JS + jQuery agregado dos componentes e da página.
       JS puro roda direto; jQuery roda dentro de jQuery(function($){...}). -->
  {combinedScript.trim() && (
    <script set:html={combinedScript} is:inline></script>
  )}
</Layout>
