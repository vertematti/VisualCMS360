      var _imgDragStartX = 0, _imgDragStartY = 0;
      var _imgPanStartX  = 0, _imgPanStartY  = 0;
      var _imgTouches = [], _imgLastPinchDist = 0;
      var IMG_MIN = 1, IMG_MAX = 5, IMG_STEP = 0.5;
      var IMG_MIN_FS = 0.2; // permite zoom-out no fullscreen

      function imgApplyTransform(transition) {
        imgModalImg.style.transition = transition
          ? 'opacity 0.18s ease, transform 0.2s ease'
          : 'opacity 0.18s ease';
        imgModalImg.style.transform = 'scale(' + _imgScale + ') translate('
          + (_imgPanX / _imgScale) + 'px, ' + (_imgPanY / _imgScale) + 'px)';
        var isZoomed = _imgScale > 1;
        imgZoomArea.classList.toggle('zoomed', isZoomed);
        if (isZoomed) {
          imgZoomLevel.style.display = 'block';
          imgZoomLevel.textContent = Math.round(_imgScale * 100) + '%';
        } else {
          imgZoomLevel.style.display = 'none';
        }
      }

      function imgResetZoom(transition) {
        _imgScale = 1; _imgPanX = 0; _imgPanY = 0;
        imgApplyTransform(transition !== false);
      }

      function imgClampPan() {
        if (isImgFullscreen() && _imgFsW > 0) {
          /* Fullscreen: usa dimensões px reais da imagem (mesma lógica da galeria)
             → maxPanX > 0 em mobile portrait pois _imgFsW > vw */
          var vw    = window.innerWidth,  vh    = window.innerHeight;
          var rendW = _imgFsW * _imgScale, rendH = _imgFsH * _imgScale;
          var maxX  = Math.max(0, (rendW - vw) / 2);
          var maxY  = Math.max(0, (rendH - vh) / 2);
          _imgPanX = Math.max(-maxX, Math.min(maxX, _imgPanX));
          _imgPanY = Math.max(-maxY, Math.min(maxY, _imgPanY));
        } else {
          /* Modo normal: pan limitado pelo zoom do container */
          var maxX2 = (imgZoomArea.clientWidth  * (_imgScale - 1)) / 2;
          var maxY2 = (imgZoomArea.clientHeight * (_imgScale - 1)) / 2;
          _imgPanX = Math.max(-maxX2, Math.min(maxX2, _imgPanX));
          _imgPanY = Math.max(-maxY2, Math.min(maxY2, _imgPanY));
        }
      }

      function imgZoomBy(delta, transition) {
        var minScale = isImgFullscreen() ? IMG_MIN_FS : IMG_MIN;
        _imgScale = Math.max(minScale, Math.min(IMG_MAX, _imgScale + delta));
        if (_imgScale <= 1) { _imgPanX = 0; _imgPanY = 0; }
        else imgClampPan();
        imgApplyTransform(transition !== false);
      }

      // Botões de zoom
      document.getElementById('vt-img-zoom-in').onclick    = function() { imgZoomBy(+IMG_STEP); };
      document.getElementById('vt-img-zoom-out').onclick   = function() { imgZoomBy(-IMG_STEP); };
      document.getElementById('vt-img-zoom-reset').onclick = function() { imgResetZoom(true); };

      // Scroll do mouse para zoom
      imgZoomArea.addEventListener('wheel', function(e) {
        e.preventDefault();
        imgZoomBy(e.deltaY < 0 ? +IMG_STEP : -IMG_STEP, false);
      }, { passive: false });

      // Duplo clique: zoom in / reset
      imgZoomArea.addEventListener('dblclick', function() {
        _imgScale > 1 ? imgResetZoom(true) : imgZoomBy(+IMG_STEP * 2);
      });

      // Drag para pan (mouse) — também em fullscreen com scale=1
      imgZoomArea.addEventListener('mousedown', function(e) {
        if (_imgScale <= 1 && !isImgFullscreen()) return;
        _imgDragging = true;
        _imgDragStartX = e.clientX; _imgDragStartY = e.clientY;
        _imgPanStartX  = _imgPanX;  _imgPanStartY  = _imgPanY;
        imgZoomArea.classList.add('dragging');
        e.preventDefault();
      });
      window.addEventListener('mousemove', function(e) {
        if (!_imgDragging) return;
        _imgPanX = _imgPanStartX + (e.clientX - _imgDragStartX);
        _imgPanY = _imgPanStartY + (e.clientY - _imgDragStartY);
        imgClampPan();
        imgApplyTransform(false);
      });
      window.addEventListener('mouseup', function() {
        if (!_imgDragging) return;
        _imgDragging = false;
        imgZoomArea.classList.remove('dragging');
      });

      // Touch: pinch para zoom + drag para pan
      imgZoomArea.addEventListener('touchstart', function(e) {
        _imgTouches = Array.from(e.touches);
        if (_imgTouches.length === 2) {
          _imgLastPinchDist = Math.hypot(
            _imgTouches[1].clientX - _imgTouches[0].clientX,
            _imgTouches[1].clientY - _imgTouches[0].clientY
          );
        } else if (_imgTouches.length === 1 && (_imgScale > 1 || isImgFullscreen())) {
          _imgDragging   = true;
          _imgDragStartX = _imgTouches[0].clientX;
          _imgDragStartY = _imgTouches[0].clientY;
          _imgPanStartX  = _imgPanX;
          _imgPanStartY  = _imgPanY;
        }
      }, { passive: true });
      imgZoomArea.addEventListener('touchmove', function(e) {
        var touches = Array.from(e.touches);
        if (touches.length === 2) {
          e.preventDefault();
          var dist = Math.hypot(
            touches[1].clientX - touches[0].clientX,
            touches[1].clientY - touches[0].clientY
