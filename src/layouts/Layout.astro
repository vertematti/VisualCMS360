          e.preventDefault();
          _imgPanX = _imgPanStartX + (touches[0].clientX - _imgDragStartX);
          _imgPanY = _imgPanStartY + (touches[0].clientY - _imgDragStartY);
          imgClampPan();
          imgApplyTransform(false);
        }
      }, { passive: false });
      imgZoomArea.addEventListener('touchend', function() {
        _imgDragging = false; _imgTouches = [];
      });

      function openImageModal(hs) {
        imgModalImg.src = hs.imageUrl || '';
        imgModalImg.alt = hs.text     || '';
        imgResetZoom(false);

        var hasTitle = hs.text      && hs.text.trim();
        var hasDesc  = hs.imageDesc && hs.imageDesc.trim();
        if (hasTitle || hasDesc) {
          imgModalTitle.textContent   = hasTitle ? hs.text      : '';
          imgModalDesc.textContent    = hasDesc  ? hs.imageDesc : '';
          imgModalTitle.style.display = hasTitle ? 'block' : 'none';
          imgModalDesc.style.display  = hasDesc  ? 'block' : 'none';
          imgModalInfo.style.display  = 'block';
        } else {
          imgModalInfo.style.display = 'none';
        }

        imgModal.classList.add('active');
        imgModal.setAttribute('aria-hidden', 'false');
      }

      /* ── Fullscreen do modal de imagem de detalhe ── */
      var imgFsBtn  = document.getElementById('vt-img-modal-fullscreen');
      var imgEscHint = document.getElementById('vt-img-modal-esc-hint');
      var imgFsIn  = '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>';
      var imgFsOut = '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z"/></svg>';

      /* imgFakeFs: fullscreen simulado via CSS (usado quando o modal já está
         dentro do fullscreen do tour — o browser não permite fullscreen aninhado) */
      var _imgFakeFs = false;

      function isImgFullscreen() {
        var fsEl = document.fullscreenElement || document.webkitFullscreenElement;
        return _imgFakeFs || !!(fsEl && (fsEl === imgModal || imgModal.contains(fsEl)));
      }

      /* _imgFsW/_imgFsH: dimensões px da imagem no fullscreen */
      var _imgFsW = 0, _imgFsH = 0;

      /* Aplica dimensões px com calcFsScale (idêntico à galeria).
         Usa requestAnimationFrame até naturalWidth estar disponível. */
      function imgApplyFsDimensions() {
        var img = imgModalImg;
        /* Se naturalWidth ainda não está disponível, tenta no próximo frame */
        if (!img.naturalWidth) {
          requestAnimationFrame(function() {
            if (isImgFullscreen()) imgApplyFsDimensions();
          });
          return;
        }
        var vw  = window.innerWidth, vh = window.innerHeight;
        var sc  = calcFsScale(img.naturalWidth, img.naturalHeight, vw, vh);
        _imgFsW = Math.round(img.naturalWidth  * sc);
        _imgFsH = Math.round(img.naturalHeight * sc);
        img.style.width     = _imgFsW + 'px';
        img.style.height    = _imgFsH + 'px';
        img.style.maxWidth  = 'none';
        img.style.maxHeight = 'none';
        img.style.objectFit = 'none';
        imgApplyTransform(false);
      }

      /* applyImgFsStyles: entrada/saída do fullscreen (nativo ou fake) */
      function applyImgFsStyles(fs) {
        var za  = document.getElementById('vt-img-zoom-area');
        var img = imgModalImg;
        imgFsBtn.innerHTML       = fs ? imgFsOut : imgFsIn;
        imgFsBtn.title           = fs ? 'Sair da tela cheia (ESC)' : 'Tela cheia (F)';
        imgEscHint.style.display = fs ? 'block' : 'none';
        if (fs) {
          imgModal.style.position       = 'fixed';
          imgModal.style.inset          = '0';
          imgModal.style.zIndex         = '2147483647';
          imgModal.style.display        = 'flex';
          imgModal.style.alignItems     = 'center';
          imgModal.style.justifyContent = 'center';
          imgModal.style.background     = '#000';
          za.style.position     = 'relative';
          za.style.width        = '100vw';
          za.style.height       = '100vh';
          za.style.maxWidth     = 'none';
          za.style.maxHeight    = 'none';
          za.style.overflow     = 'hidden';
          za.style.borderRadius = '0';
          za.style.boxShadow    = 'none';
          za.style.background   = '#000';
          za.style.cursor       = 'grab';
          /* Contain provisório garante que a imagem seja visível enquanto
             imgApplyFsDimensions aguarda naturalWidth via rAF */
          img.style.width     = '100%';
          img.style.height    = '100%';
          img.style.maxWidth  = 'none';
          img.style.maxHeight = 'none';
          img.style.objectFit = 'contain';
          img.style.borderRadius = '0';
          _imgScale = 1; _imgPanX = 0; _imgPanY = 0;
          imgApplyTransform(false);
          /* Aplica dimensões px reais (com rAF se naturalWidth ainda não disponível) */
          imgApplyFsDimensions();
        } else {
          imgModal.style.position       = '';
          imgModal.style.inset          = '';
          imgModal.style.zIndex         = '';
          imgModal.style.display        = '';
          imgModal.style.alignItems     = '';
          imgModal.style.justifyContent = '';
          imgModal.style.background     = '';
          za.style.position     = '';
          za.style.width        = ''; za.style.height      = '';
          za.style.maxWidth     = ''; za.style.maxHeight   = '';
          za.style.overflow     = '';
          za.style.borderRadius = ''; za.style.boxShadow   = '';
          za.style.background   = ''; za.style.cursor      = '';
          img.style.width       = ''; img.style.height     = '';
          img.style.maxWidth    = ''; img.style.maxHeight  = '';
          img.style.objectFit   = ''; img.style.borderRadius = '';
          _imgFsW = 0; _imgFsH = 0;
          _imgScale = 1; _imgPanX = 0; _imgPanY = 0;
          imgApplyTransform(false);
        }
      }

      /* Ambos os modos usam a mesma função */
      function applyImgFakeFs(fs)           { applyImgFsStyles(fs); }
      function applyImgFullscreenStyles(fs) { applyImgFsStyles(fs); }

      function toggleImgFullscreen() {
        /* Se o modal está dentro do fullscreen do tour, usar fake fullscreen */
        if (imgModal._vtFS) {
          _imgFakeFs = !_imgFakeFs;
          applyImgFakeFs(_imgFakeFs);
          return;
        }
        /* Fullscreen nativo quando não há tour em fullscreen */
        if (!isImgFullscreen()) {
          (imgModal.requestFullscreen || imgModal.webkitRequestFullscreen).call(imgModal);
        } else {
          (document.exitFullscreen || document.webkitExitFullscreen).call(document);
        }
      }
      imgFsBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        toggleImgFullscreen();
      });

      /* Ao fechar o modal, garantir reset do fake-fullscreen */
      document.addEventListener('fullscreenchange', function() {
        if (!imgModal.classList.contains('active')) return;
        if (!imgModal._vtFS) applyImgFullscreenStyles(isImgFullscreen());
      });
      document.addEventListener('webkitfullscreenchange', function() {
        if (!imgModal.classList.contains('active')) return;
        if (!imgModal._vtFS) applyImgFullscreenStyles(isImgFullscreen());
      });

      function closeImageModal() {
        if (_imgFakeFs) {
          /* Limpar fake-fullscreen inline styles antes de fechar */
          _imgFakeFs = false;
          applyImgFakeFs(false);
        } else {
          /* Atualizar apenas ícone do botão */
          applyImgFullscreenStyles(false);
        }
        /* Sair do fullscreen nativo se necessário */
        var fsEl = document.fullscreenElement || document.webkitFullscreenElement;
        if (fsEl && (fsEl === imgModal || imgModal.contains(fsEl))) {
