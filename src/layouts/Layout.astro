        closeImageModal();
      });
      imgModal.addEventListener('click', function(e) {
        e.stopPropagation();
        if (e.target === imgModal) closeImageModal();
      });
      document.addEventListener('keydown', function(e) {
        if (!imgModal.classList.contains('active')) return;
        if (e.key === 'Escape') {
          if (_imgFakeFs) { /* ESC sai do fake-fullscreen sem fechar o modal */
            _imgFakeFs = false;
            applyImgFakeFs(false);
            e.stopPropagation();
          } else {
            closeImageModal();
          }
        }
        if (e.key === '+' || e.key === '=')         imgZoomBy(+IMG_STEP);
        if (e.key === '-')                          imgZoomBy(-IMG_STEP);
        if (e.key === '0')                          imgResetZoom(true);
        if (e.key === 'f' || e.key === 'F')         toggleImgFullscreen();
      });

      /* ── Modal de vídeo plano ─────────────────────────────────────────── */
      var vmod        = document.getElementById('vt-video-modal');
      var vmodPlayer  = document.getElementById('vt-vmod-player');
      var vmodTitle   = document.getElementById('vt-vmod-title');
      var vmodClose   = document.getElementById('vt-vmod-close');

      function openVideoModal(hs) {
        /* 1. Limpar o player completamente */
        vmodPlayer.pause();
        vmodPlayer.removeAttribute('src');
        vmodPlayer.load();

        /* 2. Configurar título e abrir modal */
        vmodTitle.textContent = hs.text || '';
        vmod.classList.add('active');
        vmod.setAttribute('aria-hidden', 'false');

        /* 3. Setar src APÓS o modal estar visível (evita tela preta em alguns browsers) */
        requestAnimationFrame(function() {
          vmodPlayer.src      = hs.videoUrl  || '';
          vmodPlayer.loop     = !!hs.videoLoop;
          vmodPlayer.muted    = !!hs.videoMuted;
          vmodPlayer.controls = true;
          vmodPlayer.load();

          /* 4. Tentar play após browser indicar que pode reproduzir */
          vmodPlayer.addEventListener('canplay', function onCanPlay() {
            vmodPlayer.removeEventListener('canplay', onCanPlay);
            if (vmod.classList.contains('active')) {
              vmodPlayer.play().catch(function() {
                /* Bloqueado pelo browser — controles já visíveis, usuário clica */
              });
            }
          });
        });
      }
      function closeVideoModal() {
        vmod.classList.remove('active');
        vmod.setAttribute('aria-hidden','true');
        vmodPlayer.pause();
        vmodPlayer.src = '';

      }

      vmodClose.addEventListener('click', closeVideoModal);
      vmod.addEventListener('click', function(e){ if (e.target === vmod) closeVideoModal(); });
      document.addEventListener('keydown', function(e){
        if (e.key === 'Escape' && vmod.classList.contains('active')) closeVideoModal();
      });

      /* ── Tour virtual ─────────────────────────────────────────────────── */
      function initVirtualTours() {
        /* Guarda de rolagem na inicialização do tour ─────────────────────────
           Pannellum chama .focus() e o A-Frame chama scrollTo() ao iniciar — o
           que rolava a página até o tour. Aqui forçamos focus({preventScroll})
           durante a janela de init para o foco não rolar. A defesa PRINCIPAL,
           porém, é a LAZY INIT mais abaixo: o tour só é criado quando entra na
           viewport, então no carregamento nada dispara rolagem — vale para
           qualquer página com tour. */
        var vtAll = document.querySelectorAll('[data-gjs-type="virtual-tour"]');
        var vtPending = [];
        for (var vi = 0; vi < vtAll.length; vi++) {
          if (!vtAll[vi].dataset.vtInited) vtPending.push(vtAll[vi]);
        }
        if (vtPending.length) {
          /* preventScroll: impedir que .focus() do canvas role a página.
             Patch único e temporário em HTMLElement.prototype.focus. */
          if (!window.__vtFocusPatched && window.HTMLElement && HTMLElement.prototype.focus) {
            window.__vtFocusPatched = true;
            var vtOrigFocus = HTMLElement.prototype.focus;
            try {
              HTMLElement.prototype.focus = function (o) {
                var opt = {}; if (o) { for (var p in o) opt[p] = o[p]; } opt.preventScroll = true;
                return vtOrigFocus.call(this, opt);
              };
            } catch (e) { HTMLElement.prototype.focus = vtOrigFocus; window.__vtFocusPatched = false; }
            setTimeout(function () {
              try { HTMLElement.prototype.focus = vtOrigFocus; } catch (e) {}
              window.__vtFocusPatched = false;
            }, 1500);
          }

          /* Opt-in (modal): rolar suavemente até o primeiro tour marcado.
             Isso também o traz para a viewport, ativando a lazy init dele. */
          var vtScrollTarget = null;
          for (var vj = 0; vj < vtPending.length; vj++) {
            if (vtPending[vj].getAttribute('data-scroll-on-load') === 'true') { vtScrollTarget = vtPending[vj]; break; }
          }
          if (vtScrollTarget) {
            setTimeout(function () {
              try { vtScrollTarget.scrollIntoView({ behavior: 'smooth', block: 'start' }); } catch (e) {}
            }, 250);
          }
        }

        document.querySelectorAll('[data-gjs-type="virtual-tour"]').forEach(function(el) {
          var raw = el.getAttribute('data-tour');
          if (!raw || el.dataset.vtInited) return;

          /* ── LAZY INIT (defesa geral contra o "salto") ─────────────────────
             Só criamos o Pannellum/A-Frame quando o tour entra na viewport.
             Como são essas libs que dão foco/scroll no canvas, no carregamento
             da página NADA dispara — então a página não pula até o tour, em
             qualquer página que contenha um tour. Quando o usuário rola até o
             tour, ele já está visível e a inicialização não causa salto
             perceptível (e o preventScroll acima ainda protege o foco). */
          if (!el.dataset.vtActivated) {
            if (!el.dataset.vtObserving) {
              el.dataset.vtObserving = '1';
              /* Reservar a altura do tour ANTES de inicializar, para que o
                 conteúdo abaixo não "pule" (reflow) quando o tour aparecer. */
              if (!el.style.minHeight) el.style.minHeight = el.getAttribute('data-height') || '500px';
              if ('IntersectionObserver' in window) {
                var vtIO = new IntersectionObserver(function (ents, obs) {
                  for (var z = 0; z < ents.length; z++) {
                    if (ents[z].isIntersecting) {
                      ents[z].target.dataset.vtActivated = '1';
                      obs.disconnect();
                      initVirtualTours();   /* reexecuta; agora este tour passa do gate */
                      break;
                    }
                  }
                }, { root: null, rootMargin: '300px 0px', threshold: 0.01 });
                vtIO.observe(el);
              } else {
                /* Sem IntersectionObserver: ativa no próximo tick (fallback) */
                el.dataset.vtActivated = '1';
                setTimeout(initVirtualTours, 0);
              }
            }
            return;  /* ainda fora da viewport — não inicializa agora */
          }

          var tourData;
          try {
            var enc     = el.getAttribute('data-tour-enc');
            var jsonStr = enc === 'base64'
              ? decodeURIComponent(escape(atob(raw)))
              : decodeURIComponent(raw);
            tourData = JSON.parse(jsonStr);
          } catch(e) { console.warn('[VT] Erro ao decodificar tour:', e); return; }
          if (!tourData || !tourData.scenes || !tourData.scenes.length) return;
          el.dataset.vtInited = '1';

          var showThumbs  = el.getAttribute('data-show-thumbs') !== 'false';
          var tourHeight  = el.getAttribute('data-height') || '500px';

          el.innerHTML = '';

          /* Wrapper principal */
          var viewerWrap = document.createElement('div');
          viewerWrap.className    = 'vt-viewer-wrap';
          viewerWrap.style.height = tourHeight;

          /* Containers para Pannellum e A-Frame (criados sob demanda) */
          var pannellumDiv = null;
          var aframeDiv    = null;
          var sceneInfo    = document.createElement('div');
          sceneInfo.className = 'vt-scene-info';
          viewerWrap.appendChild(sceneInfo);
          el.appendChild(viewerWrap);

          /* ── Handler GLOBAL de fullscreen para mover modais ─────────────
             Pannellum coloca pannellumDiv (ou seu filho .pnlm-container) em
             fullscreen. Quando isso acontece, elementos fora desse elemento
             (como vt-video-modal e vt-img-modal) ficam invisíveis.
             Solução: mover os modais para dentro do elemento em fullscreen. */
          function vtIsTourFs() {
            var fsEl = document.fullscreenElement || document.webkitFullscreenElement;
            return !!(fsEl && viewerWrap.contains(fsEl));
          }

          function vtMoveModals(enter) {
            var fsRoot = document.fullscreenElement || document.webkitFullscreenElement || viewerWrap;

            /* Modais (vt-video-modal, vt-img-modal) */
            ['vt-video-modal', 'vt-img-modal'].forEach(function(id) {
              var m = document.getElementById(id);
              if (!m) return;
              if (enter) {
                if (m._vtFS) return;
                m._vtFS    = { parent: m.parentNode, next: m.nextSibling };
                fsRoot.appendChild(m);
                m.style.position = 'fixed';
                m.style.zIndex   = '2147483647';
              } else {
                if (!m._vtFS) return;
                if (id === 'vt-img-modal' && typeof _imgFakeFs !== 'undefined' && _imgFakeFs) {
                  _imgFakeFs = false;
                  if (typeof applyImgFakeFs === 'function') applyImgFakeFs(false);
                }
                m._vtFS.parent.insertBefore(m, m._vtFS.next || null);
                m._vtFS          = null;
                m.style.position = '';
                m.style.zIndex   = '';
              }
            });

            /* Barra de miniaturas — mover para fsRoot em qualquer fullscreen do tour.
               Para foto 360: fsRoot é pannellumDiv (filho de viewerWrap) — thumbBar
               precisa estar DENTRO de pannellumDiv para aparecer em fullscreen.
               Para vídeo 360: fsRoot é viewerWrap — thumbBar já está lá, mas
               movemos para garantir z-index correto acima do A-Frame. */
            if (thumbBar) {
              if (enter && !thumbBar._vtFS) {
                thumbBar._vtFS = { parent: thumbBar.parentNode, next: thumbBar.nextSibling };
                fsRoot.appendChild(thumbBar);
                thumbBar.style.position = 'absolute';
                thumbBar.style.bottom   = '0';
                thumbBar.style.left     = '0';
                thumbBar.style.right    = '0';
                thumbBar.style.zIndex   = '10001';
              } else if (!enter && thumbBar._vtFS) {
                thumbBar._vtFS.parent.insertBefore(thumbBar, thumbBar._vtFS.next || null);
                thumbBar._vtFS          = null;
                thumbBar.style.position = '';
                thumbBar.style.bottom   = '';
                thumbBar.style.left     = '';
                thumbBar.style.right    = '';
                thumbBar.style.zIndex   = '';
              }
            }

            /* Controles (pnlm e aframe) e sceneInfo — mover para fsRoot em fullscreen
               Usamos fsRoot = pannellumDiv (foto) ou viewerWrap (vídeo).
               Quando NOT enter: restaurar ao viewerWrap sem z-index inline. */
            ['.vt-pnlm-controls', '.vt-aframe-controls'].forEach(function(sel) {
              /* Buscar em todo o DOM (pode ter sido movido para fora do viewerWrap) */
              var ctrl = document.querySelector(sel);
              if (!ctrl) return;
              if (enter && !ctrl._vtFS) {
                ctrl._vtFS = { parent: ctrl.parentNode, next: ctrl.nextSibling };
                fsRoot.appendChild(ctrl);
              } else if (!enter && ctrl._vtFS) {
                ctrl._vtFS.parent.insertBefore(ctrl, ctrl._vtFS.next || null);
                ctrl._vtFS = null;
              }
            });

            /* sceneInfo — mover para fsRoot em fullscreen */
            if (sceneInfo) {
              if (enter && !sceneInfo._vtFS) {
                sceneInfo._vtFS = { parent: sceneInfo.parentNode, next: sceneInfo.nextSibling };
                fsRoot.appendChild(sceneInfo);
              } else if (!enter && sceneInfo._vtFS) {
                sceneInfo._vtFS.parent.insertBefore(sceneInfo, sceneInfo._vtFS.next || null);
                sceneInfo._vtFS = null;
              }
            }
          }

          function vtOnFsChange() {
            vtMoveModals(vtIsTourFs());
          }
          document.addEventListener('fullscreenchange',        vtOnFsChange);
          document.addEventListener('webkitfullscreenchange',  vtOnFsChange);

          /* Barra de miniaturas */
          var thumbBar = null;
          if (showThumbs && tourData.scenes.length > 1) {
            thumbBar = document.createElement('div');
            thumbBar.className = 'vt-thumbnails';
            /* Dentro do viewerWrap como overlay absoluto —
               visível tanto no modo normal (posição absoluta sobre o panorama)
               quanto em fullscreen (viewerWrap é o root do fullscreen de vídeo;
               para foto Pannellum o vtMoveModals garante visibilidade). */
            viewerWrap.appendChild(thumbBar);
          }

          /* Estado atual */
          var currentSceneId = null;
          var pannellumViewer = null;

          /* ── Atualizar overlay de info ─────────────────────────────────── */
          function updateSceneInfo(scene) {
            var hasTitle = scene.title && scene.title.trim();
            var hasDesc  = scene.desc  && scene.desc.trim();
            if (hasTitle || hasDesc) {
              sceneInfo.style.display = 'block';
              sceneInfo.innerHTML =
                (hasTitle ? '<div class="vt-scene-title">' + scene.title + '</div>' : '') +
                (hasDesc  ? '<div class="vt-scene-desc">'  + scene.desc  + '</div>' : '');
            } else {
              sceneInfo.style.display = 'none';
            }
          }

          /* ── Atualizar thumb ativa ─────────────────────────────────────── */
          function activateThumb(sceneId, isVideo) {
            if (!thumbBar) return;
            thumbBar.querySelectorAll('.vt-thumb').forEach(function(t) {
              t.classList.remove('active', 'active-video');
            });
            var active = thumbBar.querySelector('[data-scene-id="' + sceneId + '"]');
            if (active) {
              active.classList.add(isVideo ? 'active-video' : 'active');
              active.scrollIntoView({ behavior:'smooth', block:'nearest', inline:'center' });
            }
          }

          /* ── Destruir A-Frame sem deixar rastros ───────────────────────── */
          function destroyAframe() {
            if (!aframeDiv) return;
            /* Pausar vídeo antes de destruir */
            var vid = aframeDiv.querySelector('video');
            if (vid) { vid.pause(); vid.src = ''; vid.load(); }
            /* Remover cena A-Frame (necessário para liberar contexto WebGL) */
            var aScene = aframeDiv.querySelector('a-scene');
            if (aScene && aScene.renderer) {
              try { aScene.renderer.dispose(); } catch(e){}
            }
            /* Limpar todos os event listeners do A-Frame antes de destruir:
               1. pause() para o loop de render e tenta limpar listeners internos
               2. exitPointerLock previne que o document fique em pointer-lock
               3. Clonar e substituir o canvas remove listeners que A-Frame
                  adicionou diretamente ao elemento canvas */
            if (aScene) {
              try { aScene.pause(); } catch(e){}
              try { aScene.halt(); } catch(e){}
              try { if (document.exitPointerLock) document.exitPointerLock(); } catch(e){}
              /* Substituir canvas por clone para remover listeners diretos no canvas */
              var oldCanvas = aScene.canvas || aframeDiv.querySelector('canvas');
              if (oldCanvas && oldCanvas.parentNode) {
                oldCanvas.parentNode.replaceChild(oldCanvas.cloneNode(false), oldCanvas);
              }
            }
            aframeDiv.innerHTML = '';
            if (aframeDiv.parentNode) aframeDiv.parentNode.removeChild(aframeDiv);
            aframeDiv = null;
            /* Remover TODOS os controles de vídeo que ficaram no viewerWrap */
            viewerWrap.querySelectorAll('.vt-aframe-controls').forEach(function(c) {
              c.parentNode && c.parentNode.removeChild(c);
            });
          }

          /* ── Destruir todos os overlays de vídeo (video-wall incluso) ─── */
          function destroyAllVideoOverlays() {
            destroyAframe();
            /* Remover overlays de video-wall que ficaram no viewerWrap */
            viewerWrap.querySelectorAll('[data-vt-wall-overlay]').forEach(function(o) {
              /* Parar vídeo e liberar WebGL */
              var v = o.querySelector('video');
              if (v) { v.pause(); v.src = ''; v.load(); }
              var sc = o.querySelector('a-scene');
              if (sc && sc.renderer) { try { sc.renderer.dispose(); } catch(e){} }
              if (o.parentNode) o.parentNode.removeChild(o);
            });
            /* Fechar modal de vídeo plano se estiver aberto */
            if (typeof closeVideoModal === 'function') closeVideoModal();
          }

          /* ── Destruir Pannellum ────────────────────────────────────────── */
          function destroyPannellum() {
            if (pannellumViewer) {
              try { pannellumViewer.destroy(); } catch(e){}
              pannellumViewer = null;
            }
            if (pannellumDiv && pannellumDiv.parentNode) {
              pannellumDiv.parentNode.removeChild(pannellumDiv);
            }
            pannellumDiv = null;
            /* Remover controles customizados do Pannellum */
            viewerWrap.querySelectorAll('.vt-pnlm-controls').forEach(function(c) {
              c.parentNode && c.parentNode.removeChild(c);
            });
          }

          /* ══════════════════════════════════════════════════════════════
             CARREGAR CENA DE FOTO 360° — Pannellum
          ══════════════════════════════════════════════════════════════ */
          function loadImageScene(scene, reenterFs) {
            var wasFs = reenterFs || vtIsTourFs();
            destroyAllVideoOverlays(); /* limpa A-Frame, video-wall e modal de vídeo */

            /* Reusar Pannellum se já existe */
            if (pannellumViewer) {
              pannellumViewer.loadScene(scene.id);
              // Atualizar imediatamente — scenechange pode não disparar via loadScene()
              currentSceneId = scene.id;
              updateSceneInfo(scene);
              activateThumb(scene.id, false);
              return;
            }

            /* Criar container Pannellum */
            pannellumDiv = document.createElement('div');
            pannellumDiv.className = 'vt-pannellum-container';
            viewerWrap.insertBefore(pannellumDiv, sceneInfo);

            /* Montar config de todas as cenas de imagem */
            var pScenes = {};

            /* Mapa de metadados das cenas — usado pelo buildHotSpots para compensação de Norte */
            var scenesMap = {};
            tourData.scenes.forEach(function(s) {
              scenesMap[s.id] = {
                north: s.north || 0,
                hfov:  s.hfov  || 100,
                yaw:   s.yaw   || 0,
                pitch: s.pitch || 0,
              };
            });

            tourData.scenes.forEach(function(s) {
              if ((s.sceneType || 'image') !== 'image') return;

              pScenes[s.id] = {
                title: '',
                type: 'equirectangular',
                panorama: s.src,
                northOffset: s.north  || 0,
                hfov:        s.hfov   || 100,
                yaw:         s.yaw    || 0,
                pitch:       s.pitch  || 0,
                hotSpots: buildHotSpots(s.hotspots || [], scenesMap)
              };
            });

            requestAnimationFrame(function(){ requestAnimationFrame(function(){
              pannellumViewer = pannellum.viewer(pannellumDiv, {
                default: {
                  firstScene: scene.id,
                  sceneFadeDuration: 300,  /* curto: o efeito visual principal é o zoom */
                  autoLoad: true,
                  showControls: true
                },
                scenes: pScenes
              });

              pannellumViewer.on('scenechange', function(newId) {
                currentSceneId = newId;
                var sc = tourData.scenes.find(function(s){ return s.id === newId; });
                if (sc) { updateSceneInfo(sc); activateThumb(newId, false); }
              });
              pannellumViewer.on('load', function() {
                var activeId = pannellumViewer.getScene();
                var activeSc = tourData.scenes.find(function(s){ return s.id === activeId; });
                if (activeSc) { updateSceneInfo(activeSc); activateThumb(activeId, false); }
                setTimeout(function(){ try { pannellumViewer.resize(); } catch(e){} }, 100);
                /* Reentrar em fullscreen se a cena anterior (vídeo) estava em fullscreen */
                if (wasFs && !vtIsTourFs()) {
                  setTimeout(function() {
                    var el = pannellumViewer.getContainer
                      ? pannellumViewer.getContainer()
                      : viewerWrap;
                    var req = viewerWrap.requestFullscreen || viewerWrap.webkitRequestFullscreen;
                    if (req) req.call(viewerWrap);
                  }, 150);
                }
              });

              window.addEventListener('resize', function(){
                try { pannellumViewer.resize(); } catch(e){}
              });

              /* ── Controles customizados do Pannellum (zoom + fullscreen) ─ */
              /* Remover controles antigos se existirem */
              viewerWrap.querySelectorAll('.vt-pnlm-controls').forEach(function(c) {
                c.parentNode && c.parentNode.removeChild(c);
              });

              var pnlmCtrl = document.createElement('div');
              pnlmCtrl.className = 'vt-pnlm-controls';

              /* Zoom In */
              var btnZoomIn = document.createElement('button');
              btnZoomIn.className = 'vt-aframe-btn';
              btnZoomIn.title = 'Ampliar';
              btnZoomIn.innerHTML = '<svg viewBox="0 0 24 24" fill="#fff" width="18" height="18"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/><path d="M12 10h-2v2H9v-2H7V9h2V7h1v2h2v1z"/></svg>';
              btnZoomIn.addEventListener('click', function() {
                try { pannellumViewer.setHfov(pannellumViewer.getHfov() - 10, true); } catch(e) {}
              });

              /* Zoom Out */
              var btnZoomOut = document.createElement('button');
              btnZoomOut.className = 'vt-aframe-btn';
              btnZoomOut.title = 'Reduzir';
              btnZoomOut.innerHTML = '<svg viewBox="0 0 24 24" fill="#fff" width="18" height="18"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/><path d="M7 9h5v1H7z"/></svg>';
              btnZoomOut.addEventListener('click', function() {
                try { pannellumViewer.setHfov(pannellumViewer.getHfov() + 10, true); } catch(e) {}
              });

              /* Fullscreen */
              var btnPnlmFs = document.createElement('button');
              btnPnlmFs.className = 'vt-aframe-btn';
              function updatePnlmFsBtn() {
                btnPnlmFs.innerHTML = vtIsTourFs()
                  ? '<svg viewBox="0 0 24 24" fill="#fff" width="18" height="18"><path d="M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z"/></svg>'
                  : '<svg viewBox="0 0 24 24" fill="#fff" width="18" height="18"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>';
                btnPnlmFs.title = vtIsTourFs() ? 'Sair da tela cheia' : 'Tela cheia';
              }
              updatePnlmFsBtn();
              btnPnlmFs.addEventListener('click', function() {
                if (vtIsTourFs()) {
                  (document.exitFullscreen || document.webkitExitFullscreen).call(document);
                } else {
                  var req = viewerWrap.requestFullscreen || viewerWrap.webkitRequestFullscreen;
                  if (req) req.call(viewerWrap);
                }
              });
              document.addEventListener('fullscreenchange',        updatePnlmFsBtn);
              document.addEventListener('webkitfullscreenchange',  updatePnlmFsBtn);

              pnlmCtrl.appendChild(btnZoomIn);
              pnlmCtrl.appendChild(btnZoomOut);
              pnlmCtrl.appendChild(btnPnlmFs);
              viewerWrap.appendChild(pnlmCtrl);
            }); });
          }

          /* ── Construir hotSpots do Pannellum com suporte a vídeo ──────── */
          function buildHotSpots(hotspots, scenesMap) {
            scenesMap = scenesMap || {};
            return hotspots.map(function(hs) {
              var base = { pitch: hs.pitch, yaw: hs.yaw, text: hs.text || '' };

              if (hs.type === 'scene') {
                /* IMPORTANTE: usar type:'info' + createTooltipFunc para controle
                   total da navegação. clickHandlerFunc NÃO é suportado pelo
                   Pannellum para type:'info' — o clique deve ser vinculado via DOM
                   dentro do createTooltipFunc. */
                var destSceneId = hs.sceneId;
                var hsText      = hs.text || '';

                return Object.assign({}, base, {
                  type: 'info',
                  cssClass: 'pnlm-hotspot-base pnlm-scene vt-hs-scene-custom',
                  createTooltipFunc: function(container) {

                    /* ── Ícone: replicar exatamente o SVG padrão do Pannellum ── */
                    var iconWrap = document.createElement('div');
                    iconWrap.className = 'vt-hs-icon';
                    iconWrap.innerHTML =
                      '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" width="30" height="30">' +
                        '<circle cx="50" cy="50" r="50" fill="rgba(234,179,8,0.85)"/>' +
                        '<polygon points="50,18 76,65 50,52 24,65" fill="white"/>' +
                      '</svg>';
                    container.appendChild(iconWrap);

                    /* ── Label do hotspot ── */
                    if (hsText) {
                      var label = document.createElement('div');
                      label.className = 'vt-hs-label';
                      label.textContent = hsText;
                      container.appendChild(label);
                    }

                    /* ── Vincular clique ao próprio container (pnlm-tooltip)
                       e também ao hotspot pai para máxima compatibilidade ── */
                    container.style.cursor = 'pointer';
                    container.style.pointerEvents = 'auto';

                    function handleNavClick(e) {
                      e.stopPropagation();
                      e.preventDefault();

                      if (window.__vtNavigating || !pannellumViewer || !destSceneId) return;
                      window.__vtNavigating = true;

                      var activeScene  = pannellumViewer.getScene();
                      var currentYaw   = pannellumViewer.getYaw();
                      var currentPitch = pannellumViewer.getPitch();
                      var currentHfov  = pannellumViewer.getHfov();

                      /* Compensação de Norte — preserva direção geográfica real:
                         A propriedade 'north' armazena o Yaw (em graus) onde fica o Norte.
                         Azimute (bússola) = Yaw Atual - Norte da Cena
                         
                         Para manter o mesmo Azimute na Cena B:
                           Yaw_A - Norte_A = Yaw_B - Norte_B
                           Yaw_B = Yaw_A - Norte_A + Norte_B
                      */
                      var originNorth = (scenesMap[activeScene] || {}).north || 0;
                      var destNorth   = (scenesMap[destSceneId] || {}).north || 0;
                      var adjustedYaw = currentYaw - originNorth + destNorth;
                      while (adjustedYaw >  180) adjustedYaw -= 360;
                      while (adjustedYaw < -180) adjustedYaw += 360;

                      /* Animação zoom walk-in */
                      var startHfov  = currentHfov || 100;
                      var targetHfov = Math.max(startHfov * 0.25, 20);
                      var duration   = 450;
                      var startTime  = null;

                      function animateZoom(ts) {
                        if (!startTime) startTime = ts;
                        var p     = Math.min((ts - startTime) / duration, 1);
                        var eased = p * p * p; /* easeInCubic */
                        try {
                          pannellumViewer.setHfov(
                            startHfov + (targetHfov - startHfov) * eased, false);
                        } catch(err) {}

                        if (p < 1) {
                          requestAnimationFrame(animateZoom);
                        } else {
                          try {
                            pannellumViewer.loadScene(
                              destSceneId, currentPitch, adjustedYaw, startHfov);
                          } catch(err) {}
                          setTimeout(function() {
                            window.__vtNavigating = false;
                          }, 600);
                        }
                      }
                      requestAnimationFrame(animateZoom);
                    }

                    /* Vincular a ambos: container (pnlm-tooltip) e hotspot pai */
                    container.addEventListener('click', handleNavClick);
                    var hotEl = container.parentElement;
                    if (hotEl) hotEl.addEventListener('click', handleNavClick);
                  }
                });

              } else if (hs.type === 'info') {
                return Object.assign(base, { type:'info' });

              } else if (hs.type === 'url') {
                return Object.assign(base, { type:'info', URL: hs.url });

              } else if (hs.type === 'video-flat') {
                /* Tooltip com <video> embutido.
                   videoShowOnLoad=true  → painel sempre visível (CSS vt-vf-always-open)
                   videoShowOnLoad=false → painel abre só no hover/clique (CSS nativo Pannellum) */
                var capturedHsFlat = hs;
                return Object.assign(base, {
                  type: 'info',
                  cssClass: 'pnlm-hotspot-base pnlm-info vt-hs-video-flat'
                            + (capturedHsFlat.videoShowOnLoad ? ' vt-vf-always-open' : ''),
                  createTooltipFunc: function(container) {
                    /* ── Estratégia de posicionamento ────────────────────────
                       O Pannellum posiciona o hotspot via transform:translate()
                       em position:absolute. NUNCA alterar position do container.
                       O trigger fica em flow normal — container cresce com ele
                       (tamanho estável entre frames). O painel fica em
                       position:absolute — não afeta offsetWidth/Height.        ── */
                    /* Não tocar em position — Pannellum precisa de absolute */
                    container.style.display = 'inline-block';

                    /* ── Botão trigger — em flow normal, tamanho estável ── */
                    var trigIcon = document.createElement('div');
                    trigIcon.className = 'vt-vf-trigger';
                    trigIcon.style.cssText = [
                      'display:flex;align-items:center;gap:6px;',
                      'background:rgba(0,0,0,0.72);color:#fff;',
                      'font-family:sans-serif;font-size:12px;font-weight:700;',
                      'padding:5px 10px;border-radius:4px;cursor:pointer;',
                      'white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,0.5);',
                      'backdrop-filter:blur(4px);pointer-events:auto;'
                    ].join('');
                    trigIcon.innerHTML = '<svg viewBox="0 0 24 24" width="13" height="13" fill="#fff" style="flex-shrink:0"><polygon points="5,3 19,12 5,21"/></svg>'
                                      + (capturedHsFlat.text ? capturedHsFlat.text : 'Vídeo');
                    container.appendChild(trigIcon);

                    /* ── Painel de vídeo — position:absolute, flutua acima do trigger ── */
                    var panel = document.createElement('div');
                    panel.className = 'vt-vf-panel';
                    /* Centralizado horizontalmente em relação ao trigger, acima dele */
                    panel.style.cssText = [
                      'position:absolute;',
                      'width:280px;border-radius:8px;overflow:hidden;',
                      'box-shadow:0 4px 24px rgba(0,0,0,0.6);background:#000;',
                      'pointer-events:auto;display:none;z-index:10;'
                    ].join('');

                    /* Centraliza o painel sobre o ponto de ancoragem via JS,
                       pois % em position:absolute com altura auto é 0 em alguns browsers */
                    function positionPanel() {
                      var cW = container.offsetWidth  || 0;
                      var cH = container.offsetHeight || 0;
                      panel.style.left = (cW / 2 - 140) + 'px';  /* 140 = 280/2 */
                      panel.style.top  = (cH / 2 - panel.offsetHeight / 2) + 'px';
                    }

                    /* Poster (thumbnail clicável) */
                    var poster = document.createElement('div');
                    poster.style.cssText = 'width:280px;height:158px;background:#000;cursor:pointer;position:relative;display:flex;align-items:center;justify-content:center;';
                    if (capturedHsFlat.videoPoster) {
                      var pImg = document.createElement('img');
                      pImg.src = capturedHsFlat.videoPoster;
                      pImg.style.cssText = 'width:100%;height:100%;object-fit:cover;position:absolute;inset:0;';
                      poster.appendChild(pImg);
                    }
                    var playIcon = document.createElement('div');
                    playIcon.innerHTML = '<svg viewBox="0 0 24 24" width="48" height="48"><circle cx="12" cy="12" r="12" fill="rgba(0,0,0,0.55)"/><polygon points="9,7 19,12 9,17" fill="#fff"/></svg>';
                    playIcon.style.cssText = 'position:relative;z-index:2;pointer-events:none;';
                    poster.appendChild(playIcon);
                    if (capturedHsFlat.text) {
                      var lbl = document.createElement('div');
                      lbl.textContent = capturedHsFlat.text;
                      lbl.style.cssText = 'position:absolute;bottom:0;left:0;right:0;z-index:3;background:linear-gradient(transparent,rgba(0,0,0,0.8));color:#fff;font-family:sans-serif;font-size:12px;font-weight:600;padding:16px 8px 6px;pointer-events:none;';
                      poster.appendChild(lbl);
                    }

                    /* Vídeo */
                    var vid = document.createElement('video');
                    vid.src = capturedHsFlat.videoUrl || '';
                    vid.controls = true;
                    vid.loop     = !!capturedHsFlat.videoLoop;
                    vid.muted    = !!capturedHsFlat.videoMuted;
                    vid.playsinline = true;
                    vid.style.cssText = 'width:280px;display:none;background:#000;';
                    poster.addEventListener('click', function(e) {
                      e.stopPropagation(); e.preventDefault();
                      poster.style.display = 'none';
                      vid.style.display    = 'block';
                      vid.play().catch(function(){});
                    });
                    vid.addEventListener('ended', function() {
                      vid.style.display    = 'none';
                      poster.style.display = 'flex';
                      vid.currentTime = 0;
                    });
                    panel.appendChild(poster);
                    panel.appendChild(vid);

                    /* Botão fechar no painel */
                    var closeBtn = document.createElement('button');
                    closeBtn.innerHTML = '&times;';
                    closeBtn.style.cssText = 'position:absolute;top:4px;right:4px;background:rgba(0,0,0,0.6);color:#fff;border:none;border-radius:50%;width:22px;height:22px;cursor:pointer;font-size:14px;line-height:1;z-index:10;display:flex;align-items:center;justify-content:center;';
                    closeBtn.title = 'Fechar';
                    closeBtn.addEventListener('click', function(e) {
                      e.stopPropagation();
                      vid.pause();
                      panel.style.display  = 'none';
                      if (!capturedHsFlat.videoShowOnLoad) {
                        trigIcon.style.display = 'flex';
                      }
                    });
                    panel.appendChild(closeBtn);
                    container.appendChild(panel);

                    /* Abrir painel ao clicar no trigger */
                    trigIcon.addEventListener('click', function(e) {
                      e.stopPropagation(); e.preventDefault();
                      panel.style.display    = 'block';
                      if (!capturedHsFlat.videoShowOnLoad) {
                        trigIcon.style.display = 'none';
                      }
                      /* rAF: aguarda reflow para ler offsetHeight correto */
                      requestAnimationFrame(function() { positionPanel(); });
                    });

                    /* Modo showOnLoad: painel aberto, trigger oculto */
                    if (capturedHsFlat.videoShowOnLoad) {
                      panel.style.display    = 'block';
                      trigIcon.style.display = 'none';
                      /* Aguardar render para medir e posicionar */
                      requestAnimationFrame(function() { positionPanel(); });
                    }

                    /* Bloquear propagação */
                    [container, panel, vid].forEach(function(el) {
                      el.addEventListener('click', function(e) { e.stopPropagation(); });
                    });
                    if (container.parentElement) {
                      container.parentElement.addEventListener('click', function(e) { e.stopPropagation(); });
                    }
                  }
                });

              } else if (hs.type === 'video-modal') {
                /* Hotspot que abre modal overlay com player de vídeo */
                var capturedHs = hs;
                return Object.assign(base, {
                  type: 'info',
                  cssClass: 'pnlm-hotspot-base pnlm-info vt-hs-video-modal',
                  createTooltipFunc: function(container) {
                    var btn = document.createElement('div');
                    btn.style.cssText = 'display:flex;align-items:center;gap:6px;background:rgba(220,38,38,0.9);color:#fff;font-family:sans-serif;font-size:12px;font-weight:700;padding:5px 10px;border-radius:4px;cursor:pointer;white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,0.4);';
                    btn.innerHTML = '<svg viewBox="0 0 24 24" width="14" fill="#fff"><polygon points="5,3 19,12 5,21"/></svg>' + (capturedHs.text || 'Ver vídeo');

                    btn.addEventListener('click', function(e) {
                      e.stopPropagation();
                      e.preventDefault();
                      openVideoModal(capturedHs);
                    });

                    /* Impedir que cliques no container propaguem para o Pannellum */
                    container.addEventListener('click', function(e) { e.stopPropagation(); });
                    if (container.parentElement) {
                      container.parentElement.addEventListener('click', function(e) { e.stopPropagation(); });
                    }

                    container.appendChild(btn);
                  }
                });

              } else if (hs.type === 'video-wall') {
                /* Vídeo em perspectiva 3D — plano A-Frame overlay sobre Pannellum */
                var capturedWall = hs;
                var wallActive   = false;
                var wallOverlay  = null;

                return Object.assign(base, {
                  type: 'info',
                  cssClass: 'pnlm-hotspot-base pnlm-info vt-hs-video-wall',
                  createTooltipFunc: function(container) {
                    var btn = document.createElement('div');
                    btn.style.cssText = 'display:flex;align-items:center;gap:5px;background:rgba(30,30,60,0.9);color:#fff;font-family:sans-serif;font-size:12px;font-weight:700;padding:5px 10px;border-radius:4px;cursor:pointer;white-space:nowrap;';
                    btn.innerHTML = '🖼️ ' + (capturedWall.text || 'Ver vídeo');
                    container.appendChild(btn);
                  },
                  clickHandlerFunc: function() {
                    /* Desativar se já está ativo */
                    if (wallActive && wallOverlay) {
                      var oldVid = wallOverlay.querySelector('video');
                      if (oldVid) { oldVid.pause(); oldVid.src = ''; oldVid.load(); }
                      var oldScene = wallOverlay.querySelector('a-scene');
                      if (oldScene && oldScene.renderer) { try { oldScene.renderer.dispose(); } catch(e){} }
                      if (wallOverlay.parentNode) wallOverlay.parentNode.removeChild(wallOverlay);
                      wallOverlay = null;
                      wallActive  = false;
                      return;
                    }

                    wallActive = true;
                    var pitch  = capturedWall.pitch      || 0;
                    var yaw    = capturedWall.yaw        || 0;
                    var dist   = capturedWall.wallDist   || 3;
                    var width  = capturedWall.wallWidth  || 4;
                    var height = capturedWall.wallHeight || 2.25;
                    var vidId  = 'vt-wall-' + Math.random().toString(36).slice(2,7);

                    /* Coordenadas cartesianas a partir de esféricas */
                    var pitchRad = pitch * Math.PI / 180;
                    var yawRad   = yaw   * Math.PI / 180;
                    var px =  dist * Math.cos(pitchRad) * Math.sin(yawRad);
                    var py =  dist * Math.sin(pitchRad);
                    var pz = -dist * Math.cos(pitchRad) * Math.cos(yawRad);

                    var overlay = document.createElement('div');
                    overlay.style.cssText = 'position:absolute;inset:0;z-index:15;pointer-events:none;';
                    overlay.setAttribute('data-vt-wall-overlay', '1');
                    wallOverlay = overlay;

                    var aScene = document.createElement('a-scene');
                    aScene.setAttribute('embedded', '');
                    aScene.setAttribute('vr-mode-ui', 'enabled:false');
                    aScene.setAttribute('loading-screen', 'enabled:false');
                    aScene.setAttribute('renderer', 'alpha:true;antialias:true');
                    aScene.style.cssText = 'width:100%;height:100%;background:transparent;pointer-events:auto;';

                    var assets = document.createElement('a-assets');
                    var vid = document.createElement('video');
                    vid.id = vidId;
                    vid.src = capturedWall.videoUrl || '';
                    vid.crossOrigin = 'anonymous';
                    vid.loop        = !!capturedWall.videoLoop;
                    vid.muted       = !!capturedWall.videoMuted;
                    vid.playsinline = true;
                    assets.appendChild(vid);
                    aScene.appendChild(assets);

                    var cam = document.createElement('a-camera');
                    cam.setAttribute('look-controls', 'enabled:false');
                    cam.setAttribute('wasd-controls', 'enabled:false');
                    aScene.appendChild(cam);

                    var plane = document.createElement('a-video');
                    plane.setAttribute('src', '#' + vidId);
                    plane.setAttribute('width',  String(width));
                    plane.setAttribute('height', String(height));
                    plane.setAttribute('position', px + ' ' + py + ' ' + pz);
                    plane.setAttribute('rotation', pitch + ' ' + (-yaw) + ' 0');
                    plane.setAttribute('side', 'double');
                    aScene.appendChild(plane);

                    var closeBtn = document.createElement('button');
                    closeBtn.innerHTML = '<svg viewBox="0 0 24 24" fill="#fff" width="18" height="18"><path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/></svg>';
                    closeBtn.title = 'Fechar vídeo';
                    closeBtn.style.cssText = 'position:absolute;bottom:12px;left:50%;transform:translateX(-50%);background:rgba(0,0,0,0.65);color:#fff;border:none;width:38px;height:38px;border-radius:50%;cursor:pointer;z-index:20;pointer-events:auto;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(4px);transition:background .2s;';
                    closeBtn.onmouseover = function(){ closeBtn.style.background='rgba(0,0,0,0.85)'; };
                    closeBtn.onmouseout  = function(){ closeBtn.style.background='rgba(0,0,0,0.65)'; };
                    closeBtn.onclick = function() {
                      vid.pause(); vid.src = ''; vid.load();
                      try { aScene.renderer && aScene.renderer.dispose(); } catch(e){}
                      if (overlay.parentNode) overlay.parentNode.removeChild(overlay);
                      wallOverlay = null;
                      wallActive  = false;
                    };

                    /* Sincronizar câmera A-Frame com Pannellum */
                    var syncRunning = true;
                    function syncCamera() {
                      if (!syncRunning || !pannellumViewer) return;
                      try {
                        var pYaw   = pannellumViewer.getYaw()   || 0;
                        var pPitch = pannellumViewer.getPitch() || 0;
                        var pHfov  = pannellumViewer.getHfov()  || 100;
                        var camEl  = aScene.querySelector('a-camera');
                        if (camEl) {
                          camEl.setAttribute('rotation', (-pPitch) + ' ' + (-pYaw) + ' 0');
                          camEl.setAttribute('fov', String(pHfov));
                        }
                      } catch(e) {}
                      if (syncRunning) requestAnimationFrame(syncCamera);
                    }
                    closeBtn.addEventListener('click', function() { syncRunning = false; }, { once: true });

                    overlay.appendChild(aScene);
                    overlay.appendChild(closeBtn);
                    viewerWrap.appendChild(overlay);

                    aScene.addEventListener('loaded', function() {
                      vid.play().catch(function(){});
                      syncCamera();
                    });
                  }
                });

              } else if (hs.type === 'image-detail') {
                /* Hotspot que abre modal de imagem de detalhe */
                var capturedImg = hs;
                return Object.assign(base, {
                  type: 'info',
                  cssClass: 'pnlm-hotspot-base pnlm-info vt-hs-image-detail',
                  clickHandlerFunc: function(e) {
                    if (e) { e.stopPropagation(); e.preventDefault(); }
                    openImageModal(capturedImg);
                  },
                  createTooltipFunc: function(container) {
                    var btn = document.createElement('div');
                    btn.style.cssText = [
                      'display:flex;align-items:center;gap:6px;',
                      'background:rgba(99,102,241,0.9);color:#fff;',
                      'font-family:sans-serif;font-size:12px;font-weight:700;',
                      'padding:5px 10px;border-radius:4px;cursor:pointer;',
                      'white-space:nowrap;'
                    ].join('');
                    btn.innerHTML = '<svg viewBox="0 0 24 24" width="13" fill="#fff">'
                      + '<path d="M21 19V5c0-1.1-.9-2-2-2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2zM8.5 13.5l2.5 3.01L14.5 12l4.5 6H5l3.5-4.5z"/>'
                      + '</svg>'
                      + (capturedImg.text || 'Ver imagem');
                    function _openImg(e) {
                      e.stopPropagation();
                      e.preventDefault();
                      openImageModal(capturedImg);
                    }
                    btn.addEventListener('click',     _openImg);
                    btn.addEventListener('pointerup', _openImg);
                    /* Impedir propagação no container e hotspot pai */
                    container.addEventListener('click', function(e) { e.stopPropagation(); });
                    if (container.parentElement) {
                      container.parentElement.addEventListener('click', function(e) { e.stopPropagation(); });
                    }
                    container.appendChild(btn);
                  }
                });

              } else {
                /* Fallback */
                return Object.assign(base, { type:'info' });
              }
            });
          }

          /* ══════════════════════════════════════════════════════════════
             CARREGAR CENA DE VÍDEO 360° — A-Frame
          ══════════════════════════════════════════════════════════════ */
          function loadVideoScene(scene, reenterFs) {
            /* Verificar se A-Frame está disponível */
            if (typeof AFRAME === 'undefined') {
              /* Mostrar loading enquanto A-Frame carrega */
              sceneInfo.style.display = 'block';
              sceneInfo.innerHTML = '<div style="color:#a78bfa;font-size:12px;">⏳ Carregando A-Frame para vídeo 360°…</div>';

              var retries = 0;
              var maxRetries = 30; /* 15 segundos */
              var waitAframe = setInterval(function() {
                retries++;
                if (typeof AFRAME !== 'undefined') {
                  clearInterval(waitAframe);
                  sceneInfo.style.display = 'none';
                  loadVideoScene(scene);
                } else if (window.__aframeFailed || retries > maxRetries) {
                  clearInterval(waitAframe);
                  sceneInfo.style.display = 'block';
                  sceneInfo.innerHTML =
                    '<div style="color:#fca5a5;font-size:12px;line-height:1.6;">' +
                    '⚠ A-Frame não carregou.<br>' +
                    'Execute <code style="background:#1a1a2e;padding:1px 5px;border-radius:3px;">npm install</code> ' +
                    'para copiar o arquivo local,<br>ou verifique a conexão com a internet.' +
                    '<br><br>' +
                    '<button onclick="this.parentNode.parentNode.style.display=\'none\'" ' +
                    'style="background:#2a2a3e;color:#ccc;border:none;border-radius:4px;padding:4px 10px;cursor:pointer;font-size:11px;">' +
                    '✕ Fechar</button></div>';
                }
              }, 500);
              return;
            }

            /* Pausar e destruir Pannellum para liberar o contexto WebGL */
            destroyPannellum();
            destroyAllVideoOverlays(); /* limpa controles antigos antes de criar novos */

            aframeDiv = document.createElement('div');
            aframeDiv.className = 'vt-aframe-container';
            viewerWrap.insertBefore(aframeDiv, sceneInfo);

            /* ── Loading overlay ─────────────────────────────────────────── */
            var loadingEl = document.createElement('div');
            loadingEl.className = 'vt-video-loading';
            loadingEl.innerHTML = [
              '<div class="vt-spinner"></div>',
              '<div class="vt-loading-label">Carregando vídeo 360°...</div>',
              '<div class="vt-loading-progress">',
              '  <div class="vt-loading-progress-bar" id="vt-prog-' + scene.id + '"></div>',
              '</div>'
            ].join('');
            viewerWrap.appendChild(loadingEl);

            var progBar = loadingEl.querySelector('.vt-loading-progress-bar');

            function hideLoading() {
              loadingEl.classList.add('hide');
              setTimeout(function() {
                if (loadingEl.parentNode) loadingEl.parentNode.removeChild(loadingEl);
              }, 520);
            }

            /* ID único para o asset de vídeo desta cena */
            var vidId = 'vt-vid-' + scene.id;

            /* Opções de vídeo */
            var autoplay = scene.videoAutoplay !== false;
            var loop     = scene.videoLoop     !== false;
            var muted    = scene.videoMuted    !== false;

            /* Criar a-scene dinamicamente */
            var aScene = document.createElement('a-scene');
            aScene.setAttribute('embedded', '');
            aScene.setAttribute('vr-mode-ui', 'enabled: false');
            aScene.setAttribute('loading-screen', 'enabled: false');
            aScene.style.cssText = 'width:100%;height:100%;';

            /* Assets */
            var assets = document.createElement('a-assets');

            var vid = document.createElement('video');
            vid.id         = vidId;
            vid.src        = scene.src;
            vid.crossOrigin = 'anonymous';
            vid.loop       = loop;
            vid.muted      = muted;
            vid.playsinline = true;
            vid.preload    = 'auto';
            if (scene.poster) vid.poster = scene.poster;
            assets.appendChild(vid);
            aScene.appendChild(assets);

            /* Sky com textura de vídeo */
            var sky = document.createElement('a-videosphere');
            sky.setAttribute('src', '#' + vidId);
            sky.setAttribute('rotation', '0 ' + (scene.yaw || 0) + ' 0');
            sky.setAttribute('radius', '500');
            aScene.appendChild(sky);

            /* Câmera */
            var cam = document.createElement('a-camera');
            cam.setAttribute('look-controls', 'reverseMouseDrag: true');
            cam.setAttribute('wasd-controls', 'enabled: false');
            aScene.appendChild(cam);

            aframeDiv.appendChild(aScene);

            /* Controles de playback sobrepostos */
            var controls = document.createElement('div');
            controls.className = 'vt-aframe-controls';

            /* Play/Pause */
            var btnPlay = document.createElement('button');
            btnPlay.className = 'vt-aframe-btn';
            btnPlay.id = 'vt-af-play-' + scene.id;
            var isPlaying = false;

            function updatePlayBtn() {
              btnPlay.innerHTML = isPlaying
                ? '<svg viewBox="0 0 24 24" fill="#fff" title="Pausar"><rect x="6" y="4" width="4" height="16"/><rect x="14" y="4" width="4" height="16"/></svg>'
                : '<svg viewBox="0 0 24 24" fill="#fff" title="Play"><polygon points="5,3 19,12 5,21"/></svg>';
              btnPlay.title = isPlaying ? 'Pausar' : 'Play';
            }
            updatePlayBtn();

            btnPlay.addEventListener('click', function() {
              if (isPlaying) { vid.pause(); isPlaying = false; }
              else { vid.play().catch(function(){}); isPlaying = true; }
              updatePlayBtn();
            });

            /* Mudo/Som */
            var btnMute = document.createElement('button');
            btnMute.className = 'vt-aframe-btn';
            var isMuted = muted;

            function updateMuteBtn() {
              btnMute.innerHTML = isMuted
                ? '<svg viewBox="0 0 24 24" fill="#fff"><path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/></svg>'
                : '<svg viewBox="0 0 24 24" fill="#fff"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/></svg>';
              btnMute.title = isMuted ? 'Sem som' : 'Som';
            }
            updateMuteBtn();

            btnMute.addEventListener('click', function() {
              isMuted = !isMuted;
              vid.muted = isMuted;
              updateMuteBtn();
            });

            /* Botão fullscreen do vídeo 360 */
            var btnFs = document.createElement('button');
            btnFs.className = 'vt-aframe-btn';
            btnFs.title = 'Tela cheia';
            function updateFsBtn() {
              btnFs.innerHTML = vtIsTourFs()
                ? '<svg viewBox="0 0 24 24" fill="#fff" width="18" height="18"><path d="M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z"/></svg>'
                : '<svg viewBox="0 0 24 24" fill="#fff" width="18" height="18"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>';
              btnFs.title = vtIsTourFs() ? 'Sair da tela cheia' : 'Tela cheia';
            }
            updateFsBtn();
            btnFs.addEventListener('click', function() {
              if (vtIsTourFs()) {
                (document.exitFullscreen || document.webkitExitFullscreen).call(document);
              } else {
                var req = viewerWrap.requestFullscreen || viewerWrap.webkitRequestFullscreen;
                if (req) req.call(viewerWrap);
              }
            });
            /* Atualizar ícone ao mudar estado de fullscreen */
            document.addEventListener('fullscreenchange',       updateFsBtn);
            document.addEventListener('webkitfullscreenchange', updateFsBtn);

            controls.appendChild(btnPlay);
            controls.appendChild(btnMute);
            controls.appendChild(btnFs);

            /* Hint ESC ao entrar em fullscreen pelo botão nativo do Pannellum/browser */
            var escHint = document.createElement('div');
            escHint.style.cssText = [
              'position:absolute;top:12px;left:50%;transform:translateX(-50%);',
              'background:rgba(0,0,0,0.65);color:#fff;',
              'font-family:sans-serif;font-size:12px;',
              'padding:5px 14px;border-radius:20px;',
              'backdrop-filter:blur(4px);pointer-events:none;',
              'opacity:0;transition:opacity .4s;z-index:20;',
              'white-space:nowrap;'
            ].join('');
            escHint.textContent = 'Pressione ESC para sair do fullscreen';
            viewerWrap.appendChild(escHint);

            document.addEventListener('fullscreenchange', function() {
              /* escHint — hint de ESC para o vídeo 360 */
              if (vtIsTourFs()) {
                escHint.style.opacity = '1';
                setTimeout(function() { escHint.style.opacity = '0'; }, 3000);
              } else {
                escHint.style.opacity = '0';
              }
            });
            viewerWrap.appendChild(controls);

            /* Autoplay após o vídeo carregar */
            /* Progresso via evento progress do vídeo */
            vid.addEventListener('progress', function() {
              if (!vid.duration || !vid.buffered.length) return;
              var pct = (vid.buffered.end(vid.buffered.length - 1) / vid.duration) * 100;
              if (progBar) progBar.style.width = Math.min(pct, 95) + '%';
            });

            /* Remover loading quando vídeo estiver pronto para tocar */
            vid.addEventListener('canplay', function() {
              if (progBar) progBar.style.width = '100%';
              setTimeout(hideLoading, 200);
            });

            aScene.addEventListener('loaded', function() {
              if (autoplay) {
                vid.play().then(function() { isPlaying = true; updatePlayBtn(); }).catch(function(){});
              }
              /* Fallback: se canplay não disparou, remover loading após A-Frame carregar */
              setTimeout(function() {
                if (loadingEl.parentNode) hideLoading();
              }, 500);
              /* Reentrar em fullscreen se a cena anterior estava em fullscreen */
              if (reenterFs && !vtIsTourFs()) {
                setTimeout(function() {
                  var req = viewerWrap.requestFullscreen || viewerWrap.webkitRequestFullscreen;
                  if (req) req.call(viewerWrap);
                }, 100);
              }
            });

            vid.addEventListener('play',  function(){ isPlaying = true;  updatePlayBtn(); });
            vid.addEventListener('pause', function(){ isPlaying = false; updatePlayBtn(); });
            vid.addEventListener('error', function() {
              if (loadingEl.parentNode) {
                loadingEl.querySelector('.vt-loading-label').textContent = '⚠ Erro ao carregar o vídeo';
                loadingEl.querySelector('.vt-spinner').style.display = 'none';
              }
            });

            updateSceneInfo(scene);
            activateThumb(scene.id, true);
          }

          /* ── Navegar para uma cena (detecta tipo) ─────────────────────── */
          function goToScene(scene) {
            currentSceneId = scene.id;
            /* Guardar estado de fullscreen — A-Frame chama exitFullscreen
               internamente ao destruir a a-scene; precisamos reentrar depois */
            var wasFs = vtIsTourFs();
            if ((scene.sceneType || 'image') === 'video') {
              loadVideoScene(scene, wasFs);
            } else {
              loadImageScene(scene, wasFs);
            }
          }

          /* ── Primeira cena ────────────────────────────────────────────── */
          goToScene(tourData.scenes[0]);

          /* ── Thumbnails ───────────────────────────────────────────────── */
          if (thumbBar) {
            tourData.scenes.forEach(function(scene) {
              var isVid  = (scene.sceneType || 'image') === 'video';
              var thumb  = document.createElement('div');
              thumb.className = 'vt-thumb';
              thumb.dataset.sceneId = scene.id;

              var thumbSrc = isVid ? (scene.poster || '') : (scene.src || '');
              thumb.innerHTML =
                (thumbSrc
                  ? '<img src="' + thumbSrc + '" alt="' + (scene.title || '') + '">'
                  : '<div style="width:100%;height:100%;background:#1a1a2e;display:flex;align-items:center;justify-content:center;font-size:18px;">' + (isVid ? '🎬' : '🌐') + '</div>')
                + (scene.title ? '<div class="vt-thumb-label">' + scene.title + '</div>' : '')
                + (isVid ? '<div class="vt-thumb-video-badge">▶ VID</div>' : '');

              thumb.addEventListener('click', function() { goToScene(scene); });
              thumbBar.appendChild(thumb);
            });
          }
        });
      }

      /* Aguardar Pannellum + A-Frame estarem prontos */
      function waitAndInit() {
        // Pannellum é obrigatório. A-Frame é opcional (só para cenas de vídeo).
        // Não bloquear a inicialização se apenas o A-Frame ainda não carregou.
        if (typeof pannellum !== 'undefined') {
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initVirtualTours);
          } else {
            initVirtualTours();
          }
        } else {
          // Pannellum ainda não carregou — aguardar load completo
          window.addEventListener('load', initVirtualTours);
        }
      }
      waitAndInit();
    })();
  </script>

</body>
</html>
