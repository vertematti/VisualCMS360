import '../styles/global.css';

interface Props {
  lang?: string;
  seoTags?: string;   // bloco HTML de <meta>/<title>/JSON-LD já resolvido
}
const { lang = 'pt-BR', seoTags = '' } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- Favicons -->
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  {seoTags
    ? <Fragment set:html={seoTags} />
    : <title>Visual CMS</title>}
  <!-- Font Awesome local -->
  <link rel="stylesheet" href="/vendor/fontawesome/css/all.min.css" />
  <!-- jQuery local -->
  <script is:inline src="/vendor/jquery.min.js"></script>
  <!-- Tailwind local (CDN-play via script) -->
  <script is:inline>
    /* Garantir que Tailwind via script funcione no site publicado */
  </script>
</head>
<body>
  <slot />
  <!-- ── Gallery Lightbox Runtime (usado nas páginas publicadas) ── -->
  <style is:global>
    #gallery-lightbox {
      position: fixed; inset: 0; z-index: 100000;
      background: rgba(0,0,0,0.92);
      display: flex; align-items: center; justify-content: center;
      opacity: 0; pointer-events: none;
      transition: opacity 0.25s ease;
    }
    #gallery-lightbox.active { opacity: 1; pointer-events: all; }
    /* Área de zoom — overflow hidden para clipar a imagem ampliada */
    #glb-zoom-area {
      position: relative;
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
      max-width: 88vw; max-height: 85vh;
      border-radius: 6px;
      box-shadow: 0 8px 60px rgba(0,0,0,0.7);
      cursor: grab;
      user-select: none;
      touch-action: none;
    }
    #glb-zoom-area.dragging { cursor: grabbing; }
    #glb-zoom-area.zoomed  { cursor: grab; }
    #gallery-lightbox img {
      display: block;
      max-width: 88vw; max-height: 85vh;
      object-fit: contain;
      border-radius: 6px;
      transition: opacity 0.18s ease, transform 0.15s ease;
      transform-origin: center center;
      pointer-events: none;
      user-select: none;
    }
    #gallery-lightbox img.fading { opacity: 0; }
    .glb-btn {
      position: absolute; top: 50%; transform: translateY(-50%);
      background: rgba(255,255,255,0.13); border: none; color: #fff;
      font-size: 26px; width: 50px; height: 50px; border-radius: 50%;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      transition: background 0.2s; user-select: none; z-index: 10;
    }
    .glb-btn:hover { background: rgba(255,255,255,0.28); }
    #glb-prev { left: 16px; }
    #glb-next { right: 16px; }
    #glb-close {
      position: absolute; top: 14px; right: 16px;
      background: rgba(255,255,255,0.13); border: none; color: #fff;
      font-size: 18px; width: 38px; height: 38px; border-radius: 50%;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      transition: background 0.2s; z-index: 10;
    }
    #glb-close:hover { background: rgba(255,255,255,0.28); }
    /* Controles de zoom */
    #glb-zoom-controls {
      position: absolute; top: 14px; left: 16px;
      display: flex; gap: 6px; z-index: 10;
    }
    .glb-zoom-btn {
      background: rgba(255,255,255,0.13); border: none; color: #fff;
      font-size: 18px; width: 38px; height: 38px; border-radius: 50%;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      transition: background 0.2s; font-weight: 700; line-height: 1;
    }
    .glb-zoom-btn:hover { background: rgba(255,255,255,0.28); }
    #glb-zoom-level {
      position: absolute; top: 14px; left: 50%; transform: translateX(-50%);
      color: rgba(255,255,255,0.5); font-size: 12px; font-family: sans-serif;
      pointer-events: none; z-index: 10; display: none;
    }
    #glb-counter {
      position: absolute; bottom: 16px; left: 50%; transform: translateX(-50%);
      color: rgba(255,255,255,0.55); font-size: 13px; font-family: sans-serif; letter-spacing: 1px;
      z-index: 10;
    }
    /* Botão fullscreen da galeria */
    #glb-fullscreen {
      position: absolute; top: 14px; right: 62px;
      background: rgba(255,255,255,0.13); border: none; color: #fff;
      font-size: 16px; width: 38px; height: 38px; border-radius: 50%;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      transition: background 0.2s; z-index: 10;
    }
    #glb-fullscreen:hover { background: rgba(255,255,255,0.28); }
    /* Hint ESC no fullscreen */
    #glb-esc-hint {
      position: absolute; bottom: 48px; left: 50%; transform: translateX(-50%);
      background: rgba(0,0,0,0.6); color: rgba(255,255,255,0.75);
      padding: 4px 14px; border-radius: 20px; font-size: 11px;
      font-family: sans-serif; pointer-events: none; z-index: 11;
      display: none; white-space: nowrap;
    }
    /* No fullscreen: imagem ocupa toda a tela sem bordas pretas */
    #gallery-lightbox:fullscreen,
    #gallery-lightbox:-webkit-full-screen {
      background: #000;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    #gallery-lightbox:fullscreen #glb-zoom-area,
    #gallery-lightbox:-webkit-full-screen #glb-zoom-area {
      position: relative;
      width: 100vw;
      height: 100vh;
      max-width: 100vw;
      max-height: 100vh;
      border-radius: 0;
      box-shadow: none;
      background: #000;
    }
    #gallery-lightbox:fullscreen #glb-img,
    #gallery-lightbox:-webkit-full-screen #glb-img {
      width: auto;
      height: auto;
      max-width: 100vw;
      max-height: 100vh;
      object-fit: contain;
      border-radius: 0;
    }
    /* Botões reposicionados em fullscreen (saem do flex-center, voltam ao absolute normal) */
    #gallery-lightbox:fullscreen .glb-btn,
    #gallery-lightbox:-webkit-full-screen .glb-btn {
      position: absolute;
      z-index: 10001;
    }
    #gallery-lightbox:fullscreen #glb-prev,
    #gallery-lightbox:-webkit-full-screen #glb-prev  { left: 18px; }
    #gallery-lightbox:fullscreen #glb-next,
    #gallery-lightbox:-webkit-full-screen #glb-next  { right: 18px; }
    #gallery-lightbox:fullscreen #glb-close,
    #gallery-lightbox:-webkit-full-screen #glb-close,
    #gallery-lightbox:fullscreen #glb-fullscreen,
    #gallery-lightbox:-webkit-full-screen #glb-fullscreen,
    #gallery-lightbox:fullscreen #glb-zoom-controls,
    #gallery-lightbox:-webkit-full-screen #glb-zoom-controls,
    #gallery-lightbox:fullscreen #glb-zoom-level,
    #gallery-lightbox:-webkit-full-screen #glb-zoom-level,
    #gallery-lightbox:fullscreen #glb-counter,
    #gallery-lightbox:-webkit-full-screen #glb-counter,
    #gallery-lightbox:fullscreen #glb-esc-hint,
    #gallery-lightbox:-webkit-full-screen #glb-esc-hint {
      z-index: 10001;
    }
    [data-gjs-type="photo-gallery"] [data-lb-index] {
      cursor: pointer; overflow: hidden;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    [data-gjs-type="photo-gallery"] [data-lb-index]:hover {
      transform: scale(1.03);
      box-shadow: 0 4px 20px rgba(0,0,0,0.35);
    }
  </style>

  <div id="gallery-lightbox">
    <button class="glb-btn" id="glb-prev">&#8592;</button>
    <div id="glb-zoom-area">
      <img id="glb-img" src="" alt="" />
      <div id="glb-info" style="position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,0.82));padding:28px 20px 16px;border-radius:0 0 6px 6px;display:none;pointer-events:none;">
        <div id="glb-title" style="color:#fff;font-family:sans-serif;font-size:18px;font-weight:700;text-shadow:0 1px 4px rgba(0,0,0,0.8);margin-bottom:4px;line-height:1.3;"></div>
        <div id="glb-desc" style="color:rgba(255,255,255,0.82);font-family:sans-serif;font-size:13px;text-shadow:0 1px 3px rgba(0,0,0,0.7);line-height:1.5;white-space:pre-wrap;word-break:break-word;"></div>
      </div>
    </div>
    <button class="glb-btn" id="glb-next">&#8594;</button>
    <button id="glb-close">&#10005;</button>
    <button id="glb-fullscreen" title="Tela cheia (F)">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor">
        <path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/>
      </svg>
    </button>
    <div id="glb-esc-hint">Pressione ESC para sair da tela cheia</div>
    <div id="glb-zoom-controls">
      <button class="glb-zoom-btn" id="glb-zoom-in"  title="Ampliar">+</button>
      <button class="glb-zoom-btn" id="glb-zoom-out" title="Reduzir">−</button>
      <button class="glb-zoom-btn" id="glb-zoom-reset" title="Tamanho original" style="font-size:13px;">1:1</button>
    </div>
    <div id="glb-zoom-level"></div>
    <div id="glb-counter"></div>
  </div>

  <script>
    /* calcFsScale: compartilhada pela galeria e pelo modal de detalhe */
    function calcFsScale(iw, ih, vw, vh) {
      var isMobile = ('ontouchstart' in window) && vw < 1024;
      var isPortrait = vh > vw;
      if (isMobile && isPortrait) {
        return vh / ih;   // mobile portrait: preenche altura, pan revela laterais
      }
      return Math.min(vw / iw, vh / ih);  // contain padrão
    }

    (function () {
      let _imgs = [], _idx = 0;
      // Estado de zoom e pan
      let _scale = 1, _panX = 0, _panY = 0;
      let _dragging = false, _dragStartX = 0, _dragStartY = 0, _panStartX = 0, _panStartY = 0;
      // Touch (pinch)
      let _touches = [], _lastPinchDist = 0;

      const ov        = () => document.getElementById('gallery-lightbox');
      const imgEl     = () => document.getElementById('glb-img');
      const zoomArea  = () => document.getElementById('glb-zoom-area');
      const info      = () => document.getElementById('glb-info');
      const titleEl   = () => document.getElementById('glb-title');
      const descEl    = () => document.getElementById('glb-desc');
      const counter   = () => document.getElementById('glb-counter');
      const zoomLevel = () => document.getElementById('glb-zoom-level');

      const MIN_SCALE = 1, MAX_SCALE = 5, STEP = 0.5, MIN_SCALE_FS = 0.2;

      function applyTransform(transition = false) {
        const img = imgEl();
        if (!img) return;
        img.style.transition = transition
          ? 'opacity 0.18s ease, transform 0.2s ease'
          : 'opacity 0.18s ease';
        img.style.transform = `scale(${_scale}) translate(${_panX / _scale}px, ${_panY / _scale}px)`;
        const za = zoomArea();
        za.classList.toggle('zoomed', _scale > 1);
        const zlEl = zoomLevel();
        if (_scale > 1) {
          zlEl.style.display = 'block';
          zlEl.textContent = Math.round(_scale * 100) + '%';
        } else {
          zlEl.style.display = 'none';
        }
      }

      function resetZoom(transition = true) {
        _scale = 1; _panX = 0; _panY = 0;
        applyTransform(transition);
      }


      /* Calcula o fator de escala da imagem no fullscreen.
         Mobile portrait → prioriza altura (fill height), pan horizontal habilitado.
         Demais casos → contain padrão (cabe nos dois eixos). */
      function clampPan() {
        const img = imgEl();
        const za  = zoomArea();
        if (!img || !za) return;
        if (isGlbFullscreen()) {
          const vw = window.innerWidth, vh = window.innerHeight;
          /* Usar naturalWidth/Height * calcFsScale para pan preciso
             (img.offsetWidth = 100vw com objectFit → não reflete tamanho real do conteúdo) */
          const iw   = img.naturalWidth  || vw;
          const ih   = img.naturalHeight || vh;
          const sc   = calcFsScale(iw, ih, vw, vh);
          const baseW = iw * sc;
          const baseH = ih * sc;
          const rendW = baseW * _scale;
          const rendH = baseH * _scale;
          const maxPanX = Math.max(0, (rendW - vw) / 2);
          const maxPanY = Math.max(0, (rendH - vh) / 2);
          _panX = Math.max(-maxPanX, Math.min(maxPanX, _panX));
          _panY = Math.max(-maxPanY, Math.min(maxPanY, _panY));
        } else {
          const maxPanX = (za.clientWidth  * (_scale - 1)) / 2;
          const maxPanY = (za.clientHeight * (_scale - 1)) / 2;
          _panX = Math.max(-maxPanX, Math.min(maxPanX, _panX));
          _panY = Math.max(-maxPanY, Math.min(maxPanY, _panY));
        }
      }

      function zoomBy(delta, transition = true) {
        const minS = isGlbFullscreen() ? MIN_SCALE_FS : MIN_SCALE;
        _scale = Math.max(minS, Math.min(MAX_SCALE, _scale + delta));
        if (_scale <= 1) { _panX = 0; _panY = 0; }
        else clampPan();
        applyTransform(transition);
      }

      function open(imgs, idx) {
        if (!imgs.length) return;
        _imgs = imgs; _idx = idx;
        resetZoom(false);
        render(false);
        ov().classList.add('active');
      }
      function close() {
        if (isGlbFullscreen()) {
          (document.exitFullscreen || document.webkitExitFullscreen).call(document);
        }
        ov().classList.remove('active');
        resetZoom(false);
      }
      function nav(dir) {
        if (_scale > 1) resetZoom(false);
        imgEl().classList.add('fading');
        setTimeout(() => { _idx = (_idx + dir + _imgs.length) % _imgs.length; render(true); }, 160);
      }
      function render(fromNav) {
        const item = _imgs[_idx];
        const imgElem = imgEl();
        imgElem.src = item.src; imgElem.alt = item.alt || item.title || '';
        /* Em fullscreen, objectFit já cuida do sizing — só resetar pan */
        if (isGlbFullscreen()) {
          _panX = 0; _panY = 0;
          applyTransform(false);
        }
        counter().textContent = `${_idx + 1} / ${_imgs.length}`;
        const hasTitle = item.title && item.title.trim();
        const hasDesc  = item.desc  && item.desc.trim();
        if (hasTitle || hasDesc) {
          titleEl().textContent = item.title || ''; descEl().textContent = item.desc || '';
          titleEl().style.display = hasTitle ? 'block' : 'none';
          descEl().style.display  = hasDesc  ? 'block' : 'none';
          info().style.display = 'block';
        } else { info().style.display = 'none'; }
        const show = _imgs.length > 1;
        document.getElementById('glb-prev').style.display = show ? '' : 'none';
        document.getElementById('glb-next').style.display = show ? '' : 'none';
        if (fromNav) imgEl().classList.remove('fading');
      }

      // ── Botões de zoom ────────────────────────────────────────────────────
      document.getElementById('glb-zoom-in').onclick    = () => zoomBy(+STEP);
      document.getElementById('glb-zoom-out').onclick   = () => zoomBy(-STEP);
      document.getElementById('glb-zoom-reset').onclick = () => resetZoom(true);

      // ── Scroll do mouse para zoom ─────────────────────────────────────────
      zoomArea().addEventListener('wheel', e => {
        e.preventDefault();
        zoomBy(e.deltaY < 0 ? +STEP : -STEP, false);
      }, { passive: false });

      // ── Duplo clique: zoom in / reset ─────────────────────────────────────
      zoomArea().addEventListener('dblclick', () => {
        _scale > 1 ? resetZoom(true) : zoomBy(+STEP * 2);
      });

      // ── Drag para pan (zoom > 1, ou fullscreen com imagem maior que tela) ──
      zoomArea().addEventListener('mousedown', e => {
        if (_scale <= 1 && !isGlbFullscreen()) return;
        _dragging = true;
        _dragStartX = e.clientX; _dragStartY = e.clientY;
        _panStartX = _panX; _panStartY = _panY;
        zoomArea().classList.add('dragging');
        e.preventDefault();
      });
      window.addEventListener('mousemove', e => {
        if (!_dragging) return;
        _panX = _panStartX + (e.clientX - _dragStartX);
        _panY = _panStartY + (e.clientY - _dragStartY);
        clampPan();
        applyTransform(false);
      });
      window.addEventListener('mouseup', () => {
        _dragging = false;
        zoomArea().classList.remove('dragging');
      });

      // ── Touch: pinch para zoom + drag para pan ────────────────────────────
      zoomArea().addEventListener('touchstart', e => {
        _touches = Array.from(e.touches);
        if (_touches.length === 2) {
          _lastPinchDist = Math.hypot(
            _touches[1].clientX - _touches[0].clientX,
            _touches[1].clientY - _touches[0].clientY
          );
        } else if (_touches.length === 1 && (_scale > 1 || isGlbFullscreen())) {
          _dragging = true;
          _dragStartX = _touches[0].clientX; _dragStartY = _touches[0].clientY;
          _panStartX = _panX; _panStartY = _panY;
        }
      }, { passive: true });
      zoomArea().addEventListener('touchmove', e => {
        const touches = Array.from(e.touches);
        if (touches.length === 2) {
          e.preventDefault();
          const dist = Math.hypot(
            touches[1].clientX - touches[0].clientX,
            touches[1].clientY - touches[0].clientY
          );
          const delta = (dist - _lastPinchDist) / 80;
          _lastPinchDist = dist;
          _scale = Math.max(MIN_SCALE, Math.min(MAX_SCALE, _scale + delta));
          clampPan();
          applyTransform(false);
        } else if (touches.length === 1 && _dragging) {
          e.preventDefault();
          _panX = _panStartX + (touches[0].clientX - _dragStartX);
          _panY = _panStartY + (touches[0].clientY - _dragStartY);
          clampPan();
          applyTransform(false);
        }
      }, { passive: false });
      zoomArea().addEventListener('touchend', () => {
        _dragging = false; _touches = [];
      });

      document.getElementById('glb-close').onclick = close;
      document.getElementById('glb-prev').onclick  = () => nav(-1);
      document.getElementById('glb-next').onclick  = () => nav(+1);

      /* ── Fullscreen ── */
      const glbFs    = document.getElementById('glb-fullscreen');
      const glbEsc   = document.getElementById('glb-esc-hint');
      const glbFsIn  = '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/></svg>';
      const glbFsOut = '<svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z"/></svg>';

      function isGlbFullscreen() {
        var fsEl = document.fullscreenElement || document.webkitFullscreenElement;
        return !!(fsEl && (fsEl === ov() || ov().contains(fsEl)));
      }
      function toggleGlbFullscreen() {
        if (!isGlbFullscreen()) {
          const el = ov();
          (el.requestFullscreen || el.webkitRequestFullscreen).call(el);
        } else {
          (document.exitFullscreen || document.webkitExitFullscreen).call(document);
        }
      }
      glbFs.onclick = toggleGlbFullscreen;

      function applyGlbFullscreenStyles(fs) {
        const lb       = ov();
        const za       = zoomArea();
        const img      = imgEl();
        glbFs.innerHTML      = fs ? glbFsOut : glbFsIn;
        glbFs.title          = fs ? 'Sair da tela cheia (ESC)' : 'Tela cheia (F)';
        glbEsc.style.display = fs ? 'block' : 'none';
        if (fs) {
          lb.style.display        = 'flex';
          lb.style.alignItems     = 'center';
          lb.style.justifyContent = 'center';
          lb.style.background     = '#000';
          /* za: 100vw × 100vh — superfície real de drag */
          za.style.position       = 'relative';
          za.style.width          = '100vw';
          za.style.height         = '100vh';
          za.style.maxWidth       = 'none';
          za.style.maxHeight      = 'none';
          za.style.overflow       = 'hidden';
          za.style.borderRadius   = '0';
          za.style.boxShadow      = 'none';
          za.style.background     = '#000';
          za.style.cursor         = 'grab';
          /* img: dimensões px via calcFsScale (Math.ceil evita gap de 1px) */
          const vw = window.innerWidth, vh = window.innerHeight;
          const iw  = img.naturalWidth  || img.width  || vw;
          const ih  = img.naturalHeight || img.height || vh;
          const sc  = calcFsScale(iw, ih, vw, vh);
          img.style.width         = Math.ceil(iw * sc) + 'px';
          img.style.height        = Math.ceil(ih * sc) + 'px';
          img.style.maxWidth      = 'none';
          img.style.maxHeight     = 'none';
          img.style.objectFit     = 'none';
          img.style.borderRadius  = '0';
          _panX = 0; _panY = 0;
          applyTransform(false);
        } else {
          lb.style.display        = '';
          lb.style.alignItems     = '';
          lb.style.justifyContent = '';
          lb.style.background     = '';
          za.style.position       = '';
          za.style.width          = '';
          za.style.height         = '';
          za.style.maxWidth       = '';
          za.style.maxHeight      = '';
          za.style.overflow       = '';
          za.style.borderRadius   = '';
          za.style.boxShadow      = '';
          za.style.cursor         = '';
          img.style.width         = '';
          img.style.height        = '';
          img.style.maxWidth      = '';
          img.style.maxHeight     = '';
          img.style.objectFit     = '';
          img.style.borderRadius  = '';
          _panX = 0; _panY = 0;
          applyTransform(false);
        }
      }

      document.addEventListener('fullscreenchange', () => {
        applyGlbFullscreenStyles(isGlbFullscreen());
      });
      document.addEventListener('webkitfullscreenchange', () => {
        applyGlbFullscreenStyles(isGlbFullscreen());
      });
      ov().addEventListener('click', e => { if (e.target === ov()) close(); });
      document.addEventListener('keydown', e => {
        if (!ov().classList.contains('active')) return;
        if (e.key === 'ArrowRight') nav(+1);
        if (e.key === 'ArrowLeft')  nav(-1);
        if (e.key === 'Escape')     close();
        if (e.key === '+' || e.key === '=') zoomBy(+STEP);
        if (e.key === '-')                  zoomBy(-STEP);
        if (e.key === '0')                  resetZoom(true);
        if (e.key === 'f' || e.key === 'F') toggleGlbFullscreen();
      });
      function wireGalleries() {
        document.querySelectorAll('[data-gjs-type="photo-gallery"]').forEach(gallery => {
          // ── 1. Parsear data-images (suporta URL-encoded e JSON puro) ──────────
          let imgs = [];
          const raw = gallery.getAttribute('data-images');
          if (raw) {
            try { imgs = JSON.parse(decodeURIComponent(raw)); } catch(e) {
              try { imgs = JSON.parse(raw); } catch(e2) {
                console.warn('[Gallery] Erro ao parsear data-images:', e2);
              }
            }
          }
          if (!imgs.length) return;

          // ── 2. Se o grid já foi renderizado (data-lb-index existentes), só conecta ──
          const existingThumbs = gallery.querySelectorAll('[data-lb-index]');
          if (existingThumbs.length) {
            existingThumbs.forEach(thumb => {
              const idx = parseInt(thumb.getAttribute('data-lb-index'), 10);
              thumb.style.cursor = 'pointer';
              thumb.addEventListener('click', e => { e.stopPropagation(); open(imgs, idx); });
            });
            return;
          }

          // ── 3. Grid vazio: construir o grid de miniaturas no DOM ─────────────
          const cols   = parseInt(gallery.getAttribute('data-columns') || '3', 10);
          const gap    = gallery.getAttribute('data-gap')    || '8px';
          const radius = gallery.getAttribute('data-radius') || '6px';

          // Limpar qualquer conteúdo residual
          gallery.innerHTML = '';

          // Container grid responsivo
          const grid = document.createElement('div');
          grid.style.cssText = [
            'display:grid',
            'grid-template-columns:repeat(' + cols + ',1fr)',
            'gap:' + gap,
            'width:100%',
          ].join(';');

          imgs.forEach((item, i) => {
            const cell = document.createElement('div');
            cell.setAttribute('data-lb-index', i);
            cell.style.cssText = [
              'position:relative',
              'overflow:hidden',
              'border-radius:' + radius,
              'cursor:pointer',
              'aspect-ratio:1/1',
              'background:#111',
            ].join(';');

            const img = document.createElement('img');
            img.src = item.src;
            img.alt = item.alt || item.title || '';
            img.loading = 'lazy';
            img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;transition:transform .3s ease;pointer-events:none;';

            // Hover zoom
            cell.addEventListener('mouseenter', () => img.style.transform = 'scale(1.05)');
            cell.addEventListener('mouseleave', () => img.style.transform = '');

            // Overlay com título
            if (item.title) {
              const overlay = document.createElement('div');
              overlay.style.cssText = [
                'position:absolute',
                'bottom:0',
                'left:0',
                'right:0',
                'background:linear-gradient(transparent,rgba(0,0,0,0.75))',
                'color:#fff',
                'font-family:sans-serif',
                'font-size:13px',
                'font-weight:600',
                'padding:20px 10px 8px',
                'pointer-events:none',
                'line-height:1.3',
              ].join(';');
              overlay.textContent = item.title;
              cell.appendChild(overlay);
            }

            cell.appendChild(img);
            cell.addEventListener('click', e => { e.stopPropagation(); open(imgs, i); });
            grid.appendChild(cell);
          });

          gallery.appendChild(grid);
        });
      }
      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', wireGalleries);
      else wireGalleries();
    })();
  </script>

